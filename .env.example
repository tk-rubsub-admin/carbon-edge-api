APP_PORT=8080

DB_URL=jdbc:mysql://127.0.0.1:3306/carbon_edge?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Bangkok
DB_USERNAME=carbon_edge_user
DB_PASSWORD=change-me

APP_AUTH_TOKEN_SECRET=change-this-to-a-long-random-secret
APP_AUTH_TOKEN_TTL_MINUTES=1440
APP_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

APP_CUSTOMER_VERIFY_EMAIL_URL_BASE=https://your-frontend-domain.com/verify-email
APP_CUSTOMER_MAIL_FROM=no-reply@yourdomain.com
APP_CUSTOMER_MAIL_SUBJECT=Verify your email address

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000
